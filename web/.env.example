# Mizan — Security Posture, Measured.
# Copy to .env.local and fill in. Never commit .env.local.

# Public base URL the dashboard is reachable at. Used to build OIDC redirect
# URIs. In a containerized deploy, set this to the ingress FQDN.
APP_BASE_URL=http://localhost:8787

# --- Azure Entra app registrations ---
# The recommended path is Settings → App Registration (Graph signals) and
# Settings → Authentication (user sign-in) inside the dashboard UI. The env
# vars below are a fallback for automated provisioning and fresh installs.
#
# Graph signals app (multi-tenant, reads posture from each entity tenant):
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
# Sovereign cloud override (default is fine for commercial + UAE):
# AZURE_AUTHORITY_HOST=https://login.microsoftonline.com

# --- Storage ---
# Where SQLite + uploaded logos live. Mount a persistent volume here in containers.
# DATA_DIR=/data

# --- Demo seed ---
# Set to "true" to pre-populate 12 sample entities + 90 days of historical
# signals. Defaults to false for customer installs; true on the reference demo.
# SCSC_SEED_DEMO=false

# --- Optional hardening ---
# If set, /api/sync requires this as an X-Sync-Secret header. Pair with a
# daily Azure Function / Logic App / cron to refresh signals without a human.
# SCSC_SYNC_SECRET=
