            {
              "name": "azure-client-cert-pem",
              "keyVaultUrl": "[format('{0}secrets/{1}', reference(resourceId('Microsoft.KeyVault/vaults', variables('actualKvName')), '2023-07-01').vaultUri, variables('secretGraphCertPem'))]",
              "identity": "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('actualUamiName'))]"
            },
            {
              "name": "azure-client-cert-thumbprint",
              "keyVaultUrl": "[format('{0}secrets/{1}', reference(resourceId('Microsoft.KeyVault/vaults', variables('actualKvName')), '2023-07-01').vaultUri, variables('secretGraphCertThumbprint'))]",
              "identity": "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('actualUamiName'))]"
            },
            {
              "name": "azure-client-cert-chain",
              "keyVaultUrl": "[format('{0}secrets/{1}', reference(resourceId('Microsoft.KeyVault/vaults', variables('actualKvName')), '2023-07-01').vaultUri, variables('secretGraphCertChain'))]",
              "identity": "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('actualUamiName'))]"
            },
            {
              "name": "auth-client-secret",
              "keyVaultUrl": "[format('{0}secrets/{1}', reference(resourceId('Microsoft.KeyVault/vaults', variables('actualKvName')), '2023-07-01').vaultUri, variables('secretAuthClientSecret'))]",
              "identity": "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('actualUamiName'))]"
            },
            {
              "name": "auth-client-cert-pem",
              "keyVaultUrl": "[format('{0}secrets/{1}', reference(resourceId('Microsoft.KeyVault/vaults', variables('actualKvName')), '2023-07-01').vaultUri, variables('secretAuthCertPem'))]",
              "identity": "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('actualUamiName'))]"
            },
            {
              "name": "auth-client-cert-thumbprint",
              "keyVaultUrl": "[format('{0}secrets/{1}', reference(resourceId('Microsoft.KeyVault/vaults', variables('actualKvName')), '2023-07-01').vaultUri, variables('secretAuthCertThumbprint'))]",
              "identity": "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('actualUamiName'))]"
            },
            {
              "name": "auth-client-cert-chain",
              "keyVaultUrl": "[format('{0}secrets/{1}', reference(resourceId('Microsoft.KeyVault/vaults', variables('actualKvName')), '2023-07-01').vaultUri, variables('secretAuthCertChain'))]",
              "identity": "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('actualUamiName'))]"
            },
            {
              "name": "sync-secret",
              "keyVaultUrl": "[format('{0}secrets/{1}', reference(resourceId('Microsoft.KeyVault/vaults', variables('actualKvName')), '2023-07-01').vaultUri, variables('secretSyncSecret'))]",
              "identity": "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('actualUamiName'))]"
            }
          ]
        },
        "template": {
          "containers": [
            {
              "name": "dashboard",
              "image": "[format('{0}:{1}', parameters('containerImage'), parameters('imageTag'))]",
              "resources": {
                "cpu": "[json(parameters('cpuCores'))]",
                "memory": "[parameters('memoryGi')]"
              },
              "env": [
                {
                  "name": "APP_BASE_URL",
                  "value": "[parameters('appBaseUrl')]"
                },
                {
                  "name": "DATA_DIR",
                  "value": "/data"
                },
                {
                  "name": "SCSC_DB_PATH",
                  "value": "/local-data/scsc.sqlite"
                },
                {
                  "name": "MIZAN_DB_BACKUP_DIR",
                  "value": "/data"
                },
                {
                  "name": "NODE_ENV",
                  "value": "production"
                },
                {
                  "name": "MIZAN_AZURE_RESOURCE_ID",
                  "value": "[resourceId('Microsoft.App/containerApps', variables('actualAppName'))]"
                },
                {
                  "name": "MIZAN_KEY_VAULT_URL",
                  "value": "[reference(resourceId('Microsoft.KeyVault/vaults', variables('actualKvName')), '2023-07-01').vaultUri]"
                },
                {
                  "name": "MIZAN_KEY_VAULT_NAME",
                  "value": "[variables('actualKvName')]"
                },
                {
                  "name": "MIZAN_MANAGED_IDENTITY_CLIENT_ID",
                  "value": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('actualUamiName')), '2023-01-31').clientId]"
                },
                {
                  "name": "MIZAN_MANAGED_IDENTITY_RESOURCE_ID",
                  "value": "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('actualUamiName'))]"
                },
                {
                  "name": "CONTAINER_APP_NAME",
                  "value": "[variables('actualAppName')]"
                },
                {
                  "name": "AZURE_CLIENT_SECRET",
                  "secretRef": "azure-client-secret"
                },
                {
                  "name": "AZURE_CLIENT_CERT_PRIVATE_KEY_PEM",
                  "secretRef": "azure-client-cert-pem"
                },
                {
                  "name": "AZURE_CLIENT_CERT_THUMBPRINT",
                  "secretRef": "azure-client-cert-thumbprint"
                },
                {
                  "name": "AZURE_CLIENT_CERT_CHAIN_PEM",
                  "secretRef": "azure-client-cert-chain"
                },
                {
                  "name": "MIZAN_AUTH_CLIENT_SECRET",
                  "secretRef": "auth-client-secret"
                },
                {
                  "name": "MIZAN_AUTH_CERT_PRIVATE_KEY_PEM",
                  "secretRef": "auth-client-cert-pem"
                },
                {
                  "name": "MIZAN_AUTH_CERT_THUMBPRINT",
                  "secretRef": "auth-client-cert-thumbprint"
                },
                {
                  "name": "MIZAN_AUTH_CERT_CHAIN_PEM",
                  "secretRef": "auth-client-cert-chain"
                },
                {
                  "name": "SCSC_SYNC_SECRET",
                  "secretRef": "sync-secret"
                }
              ],
              "volumeMounts": [
                {
                  "volumeName": "data",
                  "mountPath": "/data"
                },
                {
                  "volumeName": "local-data",
                  "mountPath": "/local-data"
                }
              ],
              "probes": [
                {
                  "type": "Liveness",
                  "httpGet": {
                    "path": "/api/auth/me",
                    "port": 8787
                  },
                  "initialDelaySeconds": 30,
                  "periodSeconds": 30,
                  "timeoutSeconds": 5,
                  "failureThreshold": 5
                }
              ]
            }
          ],
          "scale": {
            "minReplicas": 1,
            "maxReplicas": 1
          },
          "volumes": [
            {
              "name": "data",
              "storageType": "NfsAzureFile",
              "storageName": "mizandata"
            },
            {
              "name": "local-data",
              "storageType": "EmptyDir"
            }
          ]
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.App/managedEnvironments', variables('actualEnvName'))]",
        "[resourceId('Microsoft.App/managedEnvironments/storages', variables('actualEnvName'), 'mizandata')]",
        "[resourceId('Microsoft.KeyVault/vaults', variables('actualKvName'))]",
        "[extensionResourceId(resourceId('Microsoft.KeyVault/vaults', variables('actualKvName')), 'Microsoft.Authorization/roleAssignments', guid(resourceId('Microsoft.KeyVault/vaults', variables('actualKvName')), resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('actualUamiName')), 'kv-secrets-officer'))]",
        "[resourceId('Microsoft.KeyVault/vaults/secrets', variables('actualKvName'), variables('secretAuthCertChain'))]",
        "[resourceId('Microsoft.KeyVault/vaults/secrets', variables('actualKvName'), variables('secretAuthCertPem'))]",
        "[resourceId('Microsoft.KeyVault/vaults/secrets', variables('actualKvName'), variables('secretAuthCertThumbprint'))]",
        "[resourceId('Microsoft.KeyVault/vaults/secrets', variables('actualKvName'), variables('secretAuthClientSecret'))]",
        "[resourceId('Microsoft.KeyVault/vaults/secrets', variables('actualKvName'), variables('secretGraphCertChain'))]",
        "[resourceId('Microsoft.KeyVault/vaults/secrets', variables('actualKvName'), variables('secretGraphCertPem'))]",
        "[resourceId('Microsoft.KeyVault/vaults/secrets', variables('actualKvName'), variables('secretGraphCertThumbprint'))]",
        "[resourceId('Microsoft.KeyVault/vaults/secrets', variables('actualKvName'), variables('secretGraphClientSecret'))]",
        "[resourceId('Microsoft.KeyVault/vaults/secrets', variables('actualKvName'), variables('secretSyncSecret'))]",
        "[resourceId('Microsoft.Authorization/roleAssignments', guid(resourceGroup().id, resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('actualUamiName')), 'container-apps-contributor'))]",
        "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('actualUamiName'))]"
      ]
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[guid(resourceGroup().id, resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('actualUamiName')), 'container-apps-contributor')]",
      "properties": {
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', variables('containerAppsContributorRoleId'))]",
        "principalId": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('actualUamiName')), '2023-01-31').principalId]",
        "principalType": "ServicePrincipal"
      },
      "dependsOn": [
        "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('actualUamiName'))]"
      ]
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "scope": "[resourceId('Microsoft.KeyVault/vaults', variables('actualKvName'))]",
      "name": "[guid(resourceId('Microsoft.KeyVault/vaults', variables('actualKvName')), resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('actualUamiName')), 'kv-secrets-officer')]",
      "properties": {
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', variables('kvSecretsOfficerRoleId'))]",
        "principalId": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('actualUamiName')), '2023-01-31').principalId]",
        "principalType": "ServicePrincipal"
      },
      "dependsOn": [
        "[resourceId('Microsoft.KeyVault/vaults', variables('actualKvName'))]",
        "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('actualUamiName'))]"
      ]
    }
  ],
  "outputs": {
    "dashboardUrl": {
      "type": "string",
      "value": "[format('https://{0}', reference(resourceId('Microsoft.App/containerApps', variables('actualAppName')), '2024-10-02-preview').configuration.ingress.fqdn)]"
    },
    "resourceGroup": {
      "type": "string",
      "value": "[resourceGroup().name]"
    },
    "managedIdentityPrincipalId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('actualUamiName')), '2023-01-31').principalId]"
    },
    "managedIdentityClientId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('actualUamiName')), '2023-01-31').clientId]"
