{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.42.1.51946",
      "templateHash": "2439431908301046078"
    }
  },
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Region for all resources. Defaults to the RG region."
      }
    },
    "containerImage": {
      "type": "string",
      "defaultValue": "ghcr.io/ohomaidi/mizan",
      "metadata": {
        "description": "Container image (registry/repo), no tag."
      }
    },
    "imageTag": {
      "type": "string",
      "defaultValue": "latest",
      "metadata": {
        "description": "Image tag. Use a semver (e.g. 1.0.2) for production, latest for pilots."
      }
    },
    "appBaseUrl": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Public base URL for the dashboard. Leave empty and the app self-discovers its URL from the incoming request."
      }
    },
    "syncSecret": {
      "type": "securestring",
      "defaultValue": ""
    },
    "cpuCores": {
      "type": "string",
      "defaultValue": "1.0"
    },
    "memoryGi": {
      "type": "string",
      "defaultValue": "2Gi"
    },
    "vnetAddressPrefix": {
      "type": "string",
      "defaultValue": "10.60.0.0/16",
      "metadata": {
        "description": "VNet CIDR. /23 minimum for the ACA subnet; /24 here leaves /24 for the PE subnet."
      }
    },
    "acaSubnetPrefix": {
      "type": "string",
      "defaultValue": "10.60.0.0/23"
    },
    "peSubnetPrefix": {
      "type": "string",
      "defaultValue": "10.60.2.0/28"
    }
  },
  "variables": {
    "namePrefix": "mizan",
    "uniq": "[uniqueString(resourceGroup().id)]",
    "storageName": "[format('{0}{1}', variables('namePrefix'), variables('uniq'))]",
    "shareName": "mizan-data"
  },
  "resources": [
    {
      "type": "Microsoft.OperationalInsights/workspaces",
      "apiVersion": "2023-09-01",
      "name": "[format('{0}-law-{1}', variables('namePrefix'), variables('uniq'))]",
      "location": "[parameters('location')]",
      "properties": {
        "sku": {
          "name": "PerGB2018"
        },
        "retentionInDays": 30
      }
    },
    {
      "type": "Microsoft.Network/virtualNetworks",
      "apiVersion": "2024-01-01",
      "name": "[format('{0}-vnet-{1}', variables('namePrefix'), variables('uniq'))]",
      "location": "[parameters('location')]",
      "properties": {
        "addressSpace": {
          "addressPrefixes": [
            "[parameters('vnetAddressPrefix')]"
          ]
        },
        "subnets": [
          {
            "name": "aca",
            "properties": {
              "addressPrefix": "[parameters('acaSubnetPrefix')]",
              "delegations": [
                {
                  "name": "aca-delegation",
                  "properties": {
                    "serviceName": "Microsoft.App/environments"
                  }
                }
              ],
              "serviceEndpoints": [
                {
                  "service": "Microsoft.Storage",
                  "locations": [
                    "[parameters('location')]"
                  ]
                }
              ]
            }
          },
          {
            "name": "pe",
            "properties": {
              "addressPrefix": "[parameters('peSubnetPrefix')]",
              "privateEndpointNetworkPolicies": "Disabled"
            }
          }
        ]
      }
    },
    {
      "type": "Microsoft.Storage/storageAccounts",
      "apiVersion": "2024-01-01",
      "name": "[variables('storageName')]",
      "location": "[parameters('location')]",
      "kind": "FileStorage",
      "sku": {
        "name": "Premium_LRS"
      },
      "properties": {
        "allowSharedKeyAccess": false,
        "allowBlobPublicAccess": false,
        "minimumTlsVersion": "TLS1_2",
        "supportsHttpsTrafficOnly": false,
        "publicNetworkAccess": "Disabled",
        "networkAcls": {
          "bypass": "AzureServices",
          "defaultAction": "Deny"
        },
        "largeFileSharesState": "Enabled"
      }
    },
    {
      "type": "Microsoft.Storage/storageAccounts/fileServices",
      "apiVersion": "2024-01-01",
      "name": "[format('{0}/{1}', variables('storageName'), 'default')]",
      "properties": {
        "protocolSettings": {
          "smb": {}
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts', variables('storageName'))]"
      ]
    },
    {
      "type": "Microsoft.Storage/storageAccounts/fileServices/shares",
      "apiVersion": "2024-01-01",
      "name": "[format('{0}/{1}/{2}', variables('storageName'), 'default', variables('shareName'))]",
      "properties": {
        "shareQuota": 100,
        "enabledProtocols": "NFS",
        "rootSquash": "NoRootSquash"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts/fileServices', variables('storageName'), 'default')]"
      ]
    },
    {
      "type": "Microsoft.Network/privateDnsZones",
      "apiVersion": "2024-06-01",
      "name": "privatelink.file.core.windows.net",
      "location": "global",
      "properties": {}
    },
    {
      "type": "Microsoft.Network/privateDnsZones/virtualNetworkLinks",
      "apiVersion": "2024-06-01",
      "name": "[format('{0}/{1}', 'privatelink.file.core.windows.net', 'vnet-link')]",
      "location": "global",
      "properties": {
        "virtualNetwork": {
          "id": "[resourceId('Microsoft.Network/virtualNetworks', format('{0}-vnet-{1}', variables('namePrefix'), variables('uniq')))]"
        },
        "registrationEnabled": false
      },
      "dependsOn": [
        "[resourceId('Microsoft.Network/privateDnsZones', 'privatelink.file.core.windows.net')]",
        "[resourceId('Microsoft.Network/virtualNetworks', format('{0}-vnet-{1}', variables('namePrefix'), variables('uniq')))]"
      ]
    },
    {
      "type": "Microsoft.Network/privateEndpoints",
      "apiVersion": "2024-01-01",
      "name": "[format('{0}-pe-file-{1}', variables('namePrefix'), variables('uniq'))]",
      "location": "[parameters('location')]",
      "properties": {
        "subnet": {
          "id": "[format('{0}/subnets/pe', resourceId('Microsoft.Network/virtualNetworks', format('{0}-vnet-{1}', variables('namePrefix'), variables('uniq'))))]"
        },
        "privateLinkServiceConnections": [
          {
            "name": "file-connection",
            "properties": {
              "privateLinkServiceId": "[resourceId('Microsoft.Storage/storageAccounts', variables('storageName'))]",
              "groupIds": [
                "file"
              ]
            }
          }
        ]
      },
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts', variables('storageName'))]",
        "[resourceId('Microsoft.Network/virtualNetworks', format('{0}-vnet-{1}', variables('namePrefix'), variables('uniq')))]"
      ]
    },
    {
      "type": "Microsoft.Network/privateEndpoints/privateDnsZoneGroups",
      "apiVersion": "2024-01-01",
      "name": "[format('{0}/{1}', format('{0}-pe-file-{1}', variables('namePrefix'), variables('uniq')), 'default')]",
      "properties": {
        "privateDnsZoneConfigs": [
          {
            "name": "privatelink-file-core-windows-net",
            "properties": {
              "privateDnsZoneId": "[resourceId('Microsoft.Network/privateDnsZones', 'privatelink.file.core.windows.net')]"
            }
          }
        ]
      },
      "dependsOn": [
        "[resourceId('Microsoft.Network/privateDnsZones', 'privatelink.file.core.windows.net')]",
        "[resourceId('Microsoft.Network/privateEndpoints', format('{0}-pe-file-{1}', variables('namePrefix'), variables('uniq')))]"
      ]
    },
    {
      "type": "Microsoft.App/managedEnvironments",
      "apiVersion": "2024-10-02-preview",
      "name": "[format('{0}-env-{1}', variables('namePrefix'), variables('uniq'))]",
      "location": "[parameters('location')]",
      "properties": {
        "appLogsConfiguration": {
          "destination": "log-analytics",
          "logAnalyticsConfiguration": {
            "customerId": "[reference(resourceId('Microsoft.OperationalInsights/workspaces', format('{0}-law-{1}', variables('namePrefix'), variables('uniq'))), '2023-09-01').customerId]",
            "sharedKey": "[listKeys(resourceId('Microsoft.OperationalInsights/workspaces', format('{0}-law-{1}', variables('namePrefix'), variables('uniq'))), '2023-09-01').primarySharedKey]"
          }
        },
        "vnetConfiguration": {
          "infrastructureSubnetId": "[format('{0}/subnets/aca', resourceId('Microsoft.Network/virtualNetworks', format('{0}-vnet-{1}', variables('namePrefix'), variables('uniq'))))]",
          "internal": false
        },
        "workloadProfiles": [
          {
            "name": "Consumption",
            "workloadProfileType": "Consumption"
          }
        ]
      },
      "dependsOn": [
        "[resourceId('Microsoft.OperationalInsights/workspaces', format('{0}-law-{1}', variables('namePrefix'), variables('uniq')))]",
        "[resourceId('Microsoft.Network/virtualNetworks', format('{0}-vnet-{1}', variables('namePrefix'), variables('uniq')))]"
      ]
    },
    {
      "type": "Microsoft.App/managedEnvironments/storages",
      "apiVersion": "2024-10-02-preview",
      "name": "[format('{0}/{1}', format('{0}-env-{1}', variables('namePrefix'), variables('uniq')), 'mizandata')]",
      "properties": {
        "nfsAzureFile": {
          "server": "[format('{0}.file.core.windows.net', variables('storageName'))]",
          "accessMode": "ReadWrite",
          "shareName": "[format('/{0}/{1}', variables('storageName'), variables('shareName'))]"
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.App/managedEnvironments', format('{0}-env-{1}', variables('namePrefix'), variables('uniq')))]",
        "[resourceId('Microsoft.Network/privateDnsZones/virtualNetworkLinks', 'privatelink.file.core.windows.net', 'vnet-link')]",
        "[resourceId('Microsoft.Network/privateEndpoints/privateDnsZoneGroups', format('{0}-pe-file-{1}', variables('namePrefix'), variables('uniq')), 'default')]",
        "[resourceId('Microsoft.Storage/storageAccounts/fileServices/shares', variables('storageName'), 'default', variables('shareName'))]",
        "[resourceId('Microsoft.Storage/storageAccounts', variables('storageName'))]"
      ]
    },
    {
      "type": "Microsoft.App/containerApps",
      "apiVersion": "2024-10-02-preview",
      "name": "[format('{0}-app-{1}', variables('namePrefix'), variables('uniq'))]",
      "location": "[parameters('location')]",
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {
        "environmentId": "[resourceId('Microsoft.App/managedEnvironments', format('{0}-env-{1}', variables('namePrefix'), variables('uniq')))]",
        "workloadProfileName": "Consumption",
        "configuration": {
          "activeRevisionsMode": "Single",
          "ingress": {
            "external": true,
            "targetPort": 8787,
            "transport": "auto",
            "traffic": [
              {
                "weight": 100,
                "latestRevision": true
              }
            ]
          },
          "secrets": "[if(empty(parameters('syncSecret')), createArray(), createArray(createObject('name', 'sync-secret', 'value', parameters('syncSecret'))))]"
        },
        "template": {
          "containers": [
            {
              "name": "dashboard",
              "image": "[format('{0}:{1}', parameters('containerImage'), parameters('imageTag'))]",
              "resources": {
                "cpu": "[json(parameters('cpuCores'))]",
                "memory": "[parameters('memoryGi')]"
              },
              "env": "[concat(createArray(createObject('name', 'APP_BASE_URL', 'value', parameters('appBaseUrl')), createObject('name', 'DATA_DIR', 'value', '/data'), createObject('name', 'NODE_ENV', 'value', 'production'), createObject('name', 'MIZAN_AZURE_RESOURCE_ID', 'value', resourceId('Microsoft.App/containerApps', format('{0}-app-{1}', variables('namePrefix'), variables('uniq'))))), if(empty(parameters('syncSecret')), createArray(), createArray(createObject('name', 'SCSC_SYNC_SECRET', 'secretRef', 'sync-secret'))))]",
              "volumeMounts": [
                {
                  "volumeName": "data",
                  "mountPath": "/data"
                }
              ],
              "probes": [
                {
                  "type": "Liveness",
                  "httpGet": {
                    "path": "/api/auth/me",
                    "port": 8787
                  },
                  "initialDelaySeconds": 30,
                  "periodSeconds": 30,
                  "timeoutSeconds": 5,
                  "failureThreshold": 5
                }
              ]
            }
          ],
          "scale": {
            "minReplicas": 1,
            "maxReplicas": 1
          },
          "volumes": [
            {
              "name": "data",
              "storageType": "NfsAzureFile",
              "storageName": "mizandata"
            }
          ]
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.App/managedEnvironments', format('{0}-env-{1}', variables('namePrefix'), variables('uniq')))]",
        "[resourceId('Microsoft.App/managedEnvironments/storages', format('{0}-env-{1}', variables('namePrefix'), variables('uniq')), 'mizandata')]"
      ]
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[guid(resourceGroup().id, resourceId('Microsoft.App/containerApps', format('{0}-app-{1}', variables('namePrefix'), variables('uniq'))), 'container-apps-contributor')]",
      "properties": {
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', '358470bc-b998-42bd-ab17-a7e34c199c0f')]",
        "principalId": "[reference(resourceId('Microsoft.App/containerApps', format('{0}-app-{1}', variables('namePrefix'), variables('uniq'))), '2024-10-02-preview', 'full').identity.principalId]",
        "principalType": "ServicePrincipal"
      },
      "dependsOn": [
        "[resourceId('Microsoft.App/containerApps', format('{0}-app-{1}', variables('namePrefix'), variables('uniq')))]"
      ]
    }
  ],
  "outputs": {
    "dashboardUrl": {
      "type": "string",
      "value": "[format('https://{0}', reference(resourceId('Microsoft.App/containerApps', format('{0}-app-{1}', variables('namePrefix'), variables('uniq'))), '2024-10-02-preview').configuration.ingress.fqdn)]"
    },
    "resourceGroup": {
      "type": "string",
      "value": "[resourceGroup().name]"
    },
    "containerAppPrincipalId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.App/containerApps', format('{0}-app-{1}', variables('namePrefix'), variables('uniq'))), '2024-10-02-preview', 'full').identity.principalId]"
    }
  }
}