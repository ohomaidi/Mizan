{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.42.1.51946",
      "templateHash": "1249427031847796812"
    }
  },
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Region. Defaults to the resource group region; override to pin a specific one (e.g. uaenorth)."
      }
    },
    "containerImage": {
      "type": "string",
      "defaultValue": "ghcr.io/ohomaidi/mizan",
      "metadata": {
        "description": "Container image (registry/repo), without the tag. Defaults to the public Mizan image on ghcr.io."
      }
    },
    "imageTag": {
      "type": "string",
      "defaultValue": "latest",
      "metadata": {
        "description": "Image tag. Pin to a semver (e.g. 1.0.0) for production; \"latest\" is fine for pilots."
      }
    },
    "appBaseUrl": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Public base URL the dashboard will be served on — used for the OIDC redirect. Leave empty to let the one-click deploy finish; after Azure assigns the ingress FQDN you update this env var and flip on auth enforcement. If you already have a custom domain, put it here."
      }
    },
    "syncSecret": {
      "type": "securestring",
      "defaultValue": "",
      "metadata": {
        "description": "Optional sync shared secret. Set this if you wire an Azure Function / Logic App to POST /api/sync daily."
      }
    },
    "cpuCores": {
      "type": "string",
      "defaultValue": "1.0",
      "metadata": {
        "description": "Container compute: cores and memory. ACA minimums are 0.25/0.5Gi."
      }
    },
    "memoryGi": {
      "type": "string",
      "defaultValue": "2Gi"
    }
  },
  "variables": {
    "namePrefix": "mizan",
    "uniq": "[uniqueString(resourceGroup().id)]"
  },
  "resources": [
    {
      "type": "Microsoft.OperationalInsights/workspaces",
      "apiVersion": "2023-09-01",
      "name": "[format('{0}-law-{1}', variables('namePrefix'), variables('uniq'))]",
      "location": "[parameters('location')]",
      "properties": {
        "sku": {
          "name": "PerGB2018"
        },
        "retentionInDays": 30
      }
    },
    {
      "type": "Microsoft.Storage/storageAccounts",
      "apiVersion": "2024-01-01",
      "name": "[format('{0}{1}', variables('namePrefix'), variables('uniq'))]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "Standard_LRS"
      },
      "kind": "StorageV2",
      "properties": {
        "allowBlobPublicAccess": false,
        "minimumTlsVersion": "TLS1_2",
        "supportsHttpsTrafficOnly": true
      }
    },
    {
      "type": "Microsoft.Storage/storageAccounts/fileServices",
      "apiVersion": "2024-01-01",
      "name": "[format('{0}/{1}', format('{0}{1}', variables('namePrefix'), variables('uniq')), 'default')]",
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts', format('{0}{1}', variables('namePrefix'), variables('uniq')))]"
      ]
    },
    {
      "type": "Microsoft.Storage/storageAccounts/fileServices/shares",
      "apiVersion": "2024-01-01",
      "name": "[format('{0}/{1}/{2}', format('{0}{1}', variables('namePrefix'), variables('uniq')), 'default', 'mizan-data')]",
      "properties": {
        "shareQuota": 50
      },
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts/fileServices', format('{0}{1}', variables('namePrefix'), variables('uniq')), 'default')]"
      ]
    },
    {
      "type": "Microsoft.App/managedEnvironments",
      "apiVersion": "2024-03-01",
      "name": "[format('{0}-env-{1}', variables('namePrefix'), variables('uniq'))]",
      "location": "[parameters('location')]",
      "properties": {
        "appLogsConfiguration": {
          "destination": "log-analytics",
          "logAnalyticsConfiguration": {
            "customerId": "[reference(resourceId('Microsoft.OperationalInsights/workspaces', format('{0}-law-{1}', variables('namePrefix'), variables('uniq'))), '2023-09-01').customerId]",
            "sharedKey": "[listKeys(resourceId('Microsoft.OperationalInsights/workspaces', format('{0}-law-{1}', variables('namePrefix'), variables('uniq'))), '2023-09-01').primarySharedKey]"
          }
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.OperationalInsights/workspaces', format('{0}-law-{1}', variables('namePrefix'), variables('uniq')))]"
      ]
    },
    {
      "type": "Microsoft.App/managedEnvironments/storages",
      "apiVersion": "2024-03-01",
      "name": "[format('{0}/{1}', format('{0}-env-{1}', variables('namePrefix'), variables('uniq')), 'mizandata')]",
      "properties": {
        "azureFile": {
          "accountName": "[format('{0}{1}', variables('namePrefix'), variables('uniq'))]",
          "accountKey": "[listKeys(resourceId('Microsoft.Storage/storageAccounts', format('{0}{1}', variables('namePrefix'), variables('uniq'))), '2024-01-01').keys[0].value]",
          "shareName": "mizan-data",
          "accessMode": "ReadWrite"
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.App/managedEnvironments', format('{0}-env-{1}', variables('namePrefix'), variables('uniq')))]",
        "[resourceId('Microsoft.Storage/storageAccounts/fileServices/shares', format('{0}{1}', variables('namePrefix'), variables('uniq')), 'default', 'mizan-data')]",
        "[resourceId('Microsoft.Storage/storageAccounts', format('{0}{1}', variables('namePrefix'), variables('uniq')))]"
      ]
    },
    {
      "type": "Microsoft.App/containerApps",
      "apiVersion": "2024-03-01",
      "name": "[format('{0}-app-{1}', variables('namePrefix'), variables('uniq'))]",
      "location": "[parameters('location')]",
      "properties": {
        "managedEnvironmentId": "[resourceId('Microsoft.App/managedEnvironments', format('{0}-env-{1}', variables('namePrefix'), variables('uniq')))]",
        "configuration": {
          "ingress": {
            "external": true,
            "targetPort": 8787,
            "transport": "auto",
            "traffic": [
              {
                "weight": 100,
                "latestRevision": true
              }
            ]
          },
          "secrets": "[if(empty(parameters('syncSecret')), createArray(), createArray(createObject('name', 'sync-secret', 'value', parameters('syncSecret'))))]"
        },
        "template": {
          "containers": [
            {
              "name": "dashboard",
              "image": "[format('{0}:{1}', parameters('containerImage'), parameters('imageTag'))]",
              "resources": {
                "cpu": "[json(parameters('cpuCores'))]",
                "memory": "[parameters('memoryGi')]"
              },
              "env": "[concat(createArray(createObject('name', 'APP_BASE_URL', 'value', parameters('appBaseUrl')), createObject('name', 'DATA_DIR', 'value', '/data'), createObject('name', 'NODE_ENV', 'value', 'production')), if(empty(parameters('syncSecret')), createArray(), createArray(createObject('name', 'SCSC_SYNC_SECRET', 'secretRef', 'sync-secret'))))]",
              "volumeMounts": [
                {
                  "volumeName": "data",
                  "mountPath": "/data"
                }
              ],
              "probes": [
                {
                  "type": "Liveness",
                  "httpGet": {
                    "path": "/api/auth/me",
                    "port": 8787
                  },
                  "initialDelaySeconds": 20,
                  "periodSeconds": 30
                }
              ]
            }
          ],
          "scale": {
            "minReplicas": 1,
            "maxReplicas": 2
          },
          "volumes": [
            {
              "name": "data",
              "storageType": "AzureFile",
              "storageName": "mizandata"
            }
          ]
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.App/managedEnvironments', format('{0}-env-{1}', variables('namePrefix'), variables('uniq')))]",
        "[resourceId('Microsoft.App/managedEnvironments/storages', format('{0}-env-{1}', variables('namePrefix'), variables('uniq')), 'mizandata')]"
      ]
    }
  ],
  "outputs": {
    "dashboardUrl": {
      "type": "string",
      "value": "[format('https://{0}', reference(resourceId('Microsoft.App/containerApps', format('{0}-app-{1}', variables('namePrefix'), variables('uniq'))), '2024-03-01').configuration.ingress.fqdn)]"
    }
  }
}