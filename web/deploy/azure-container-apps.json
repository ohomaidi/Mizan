    {
      "type": "Microsoft.App/containerApps",
      "apiVersion": "2024-10-02-preview",
      "name": "[variables('actualAppName')]",
      "location": "[parameters('location')]",
      "identity": {
        "type": "UserAssigned",
        "userAssignedIdentities": {
          "[format('{0}', resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('actualUamiName')))]": {}
        }
      },
      "properties": {
        "environmentId": "[resourceId('Microsoft.App/managedEnvironments', variables('actualEnvName'))]",
        "workloadProfileName": "Consumption",
        "configuration": {
          "activeRevisionsMode": "Single",
          "ingress": {
            "external": "[not(parameters('internalOnly'))]",
            "targetPort": 8787,
            "transport": "auto",
            "traffic": [
              {
                "weight": 100,
                "latestRevision": true
